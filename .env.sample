# ── Proyecto ──────────────────────────────────────────────────────────────────
PROJECT_NAME=magoreal
APP_PORT=8000

# ── Dominios ──────────────────────────────────────────────────────────────────
# Dominio principal de Django
DOMAIN=magoreal.com

# Dominio del cliente white-label (SitePage). nginx-deploy.sh genera un server
# block adicional por cada uno. Deben estar en ALLOWED_HOSTS y CSRF_TRUSTED_ORIGINS.
SITEPAGE_DOMAINS=cliente.dominio.com

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=magoreal.com,www.magoreal.com,cliente.dominio.com
CSRF_TRUSTED_ORIGINS=https://magoreal.com,https://www.magoreal.com,https://cliente.dominio.com
ADMIN_URL=mi-panel-secreto/

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# POSTGRES_MODE: "container" (Docker incluido) o "host" (PostgreSQL en el servidor)
POSTGRES_MODE=container
POSTGRES_DB=magoreal_db
POSTGRES_USER=magoreal_user
POSTGRES_PASSWORD=cambia-esta-contraseña
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Producción: nombre del servicio Docker
REDIS_URL=redis://redis:6379/0
# Desarrollo (Django nativo, Redis en Docker): redis://localhost:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Sin EMAIL_HOST → backend de consola (útil en dev). Con EMAIL_HOST → SMTP real.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-app
DEFAULT_FROM_EMAIL=noreply@magoreal.com

# ── Webhooks de formularios ───────────────────────────────────────────────────
# Webhook al que se reenvía cada mensaje del formulario de contacto.
# Puede ser Make, Zapier, n8n externo, etc. Vacío = solo guarda en DB.
CONTACTO_WEBHOOK_URL=

# Webhook que procesa el PDF subido en el lead magnet de licitaciones.
# Vacío = solo guarda en DB y notifica por email.
PLIEGO_DEMO_WEBHOOK_URL=

# Email al que llega la notificación de cada nuevo lead de pliego.
# Vacío = usa el email configurado en SiteConfig (admin de Django).
LEADS_NOTIFY_EMAIL=

# ── Almacenamiento de PDFs (pliegos) ─────────────────────────────────────────
# Directorio fuera del MEDIA público donde se guardan los PDFs subidos.
# Por defecto: <BASE_DIR>/volumes/pliegos_demo
# PLIEGOS_UPLOAD_ROOT=/ruta/segura/fuera/de/media

# ── Traducción (html_translator) ─────────────────────────────────────────────
# Token que Django valida en /translations/callback/. Debe coincidir con el
# valor configurado en el cliente que llama al callback (Make, n8n externo, etc.).
TRANSLATIONS_CALLBACK_TOKEN=genera-un-token-secreto-seguro

# ── Sentry (monitoreo de errores — opcional) ─────────────────────────────────
# Sin SENTRY_DSN, Sentry no se carga. Solo activo en producción (DEBUG=False).
# SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_ENV=production
# SENTRY_TRACES_RATE=0.1
