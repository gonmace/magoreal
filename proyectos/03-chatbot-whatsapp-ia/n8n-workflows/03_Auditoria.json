    {
      "parameters": {
        "jsCode": "const t = $json.messages;\n\nconst human = t[t.length-1].human;\nconst ai = t[t.length-1].ai;\n\nconst noHistory = t.length <= 1 ? true : false\n\nconst chat_history = t\n  .slice(0, -1)\n  .map(m => `human: ${m.human}\\nai: ${m.ai}`)\n  .join(\"\\n\\n\");\n\nconst state = $('When Executed by Another Workflow').first().json.state\n\nreturn [{ json: {\n  state,\n  human,\n  ai,\n  chat_history,\n  noHistory\n} }];"
      },
