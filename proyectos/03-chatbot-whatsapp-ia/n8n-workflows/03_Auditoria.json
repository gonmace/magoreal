    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\nconst nodo = (item.json.subagente && item.json.subagente !== item.json.orquestador)\n  ? item.json.subagente\n  : item.json.orquestador;\n\nreturn [\n  {\n    json: {\n      nodo\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1984,
        624
      ],
      "id": "f3b97257-ade2-41cb-b032-e3f4b86f26e1",
      "name": "nodo"
    },
    {
      "parameters": {
        "jsCode": "const auditData = $('nodo').first().json;\nlet nodoAgente = auditData.nodo;\nnodoAgente = nodoAgente.replace(/_/g, \" \");\n\nconst workflow = $input.first().json;\n\nconst nodos = workflow.nodes || [];\n\nconst nodo = nodos.find(n => n.name === nodoAgente);\n\nconst systemPrompt = nodo?.parameters?.systemMessage || nodo?.parameters?.options?.systemMessage || nodo?.parameters?.text || null;\n\nconst id = nodo.id\n\nreturn [{\n  json: {\n    nodoAgente,\n    id,\n    systemPrompt\n  }\n}];"
      },
      "id": "extract-system-message",
      "name": "Extract prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2432,
        624
      ]
    },
    {
      "parameters": {
        "jsCode": "// Sanitiza strings para PostgreSQL: elimina null byte (0x00) que causa 'invalid byte sequence for encoding UTF8'\nfunction sanitize(val) {\n  if (typeof val === 'string') return val.replace(/\\x00/g, '');\n  if (val && typeof val === 'object' && !Array.isArray(val)) {\n    const out = {};\n    for (const k of Object.keys(val)) out[k] = sanitize(val[k]);\n    return out;\n  }\n  return val;\n}\nconst items = $input.all();\nreturn items.map(item => ({ json: sanitize(item.json) }));"
      },
      "id": "sanitize-for-db-001",
      "name": "Sanitize for DB",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1312,
        624
      ]
    }
